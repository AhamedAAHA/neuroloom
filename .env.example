# Local dev (no Docker) — defaults used by scripts/run-local.sh
DATABASE_URL=sqlite+aiosqlite:///./data/neuroloom.db
REDIS_URL=memory://
GEMMA_INFERENCE_URL=http://localhost:8080

# Fireworks AI (overflow / long-context synthesis) — optional
FIREWORKS_API_KEY=your_fireworks_api_key

# AMD GPU (when running gemma-inference on AMD Developer Cloud)
ROCM_VISIBLE_DEVICES=0

# Docker / production overrides:
# DATABASE_URL=postgresql+asyncpg://neuroloom:neuroloom@postgres:5432/neuroloom
# REDIS_URL=redis://redis:6379/0
