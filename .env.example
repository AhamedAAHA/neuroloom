# Local dev — run: bash scripts/run-local.sh from repo root
DATABASE_URL=sqlite+aiosqlite:///./data/neuroloom.db
REDIS_URL=memory://
GEMMA_INFERENCE_URL=http://localhost:8080
WEB_APP_URL=http://localhost:3000

# Gemma inference backend: stub (local) | vllm (AMD GPU via vLLM)
INFERENCE_BACKEND=stub
# When INFERENCE_BACKEND=vllm on AMD Developer Cloud:
# VLLM_BASE_URL=http://localhost:8001/v1
# MODEL_NAME=google/gemma-3-4b-it
# ROCM_VISIBLE_DEVICES=0

# Fireworks AI (overflow when AMD unavailable) — optional
FIREWORKS_API_KEY=your_fireworks_api_key

# Auth JWT secret — change in production
SECRET_KEY=neuroloom-dev-secret-change-in-production

# Docker / production overrides:
# DATABASE_URL=postgresql+asyncpg://neuroloom:neuroloom@postgres:5432/neuroloom
# REDIS_URL=redis://redis:6379/0
